# ════════════════════════════════════════════════════════════════════════════
# Environment Variables - Portfolio Carlos Molina
# SECURITY HARDENED CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ──────────────────────────────────────────────────────────────────────────────
# Flask Configuration
# ──────────────────────────────────────────────────────────────────────────────
# IMPORTANT: Always set to 'false' in production!
# Debug mode exposes sensitive information and should NEVER be enabled in production
FLASK_DEBUG=false

# Secret key for session security (generate a strong random key!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=your-super-secret-key-here

# ──────────────────────────────────────────────────────────────────────────────
# Analytics (Optional)
# ──────────────────────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID
# Get yours at: https://analytics.google.com
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ──────────────────────────────────────────────────────────────────────────────
# Google Search Console (Optional)
# ──────────────────────────────────────────────────────────────────────────────
# Verification code for Google Search Console
# Get yours at: https://search.google.com/search-console
# GSC_VERIFICATION=your_verification_code

# ──────────────────────────────────────────────────────────────────────────────
# Security Notes
# ──────────────────────────────────────────────────────────────────────────────
# 1. NEVER commit the actual .env file to version control
# 2. Use strong, randomly generated values for SECRET_KEY
# 3. Rotate secrets periodically
# 4. Use Vercel environment variables for production deployment
# 5. Review SECURITY.md for vulnerability reporting procedures
